<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>

  <Style TargetType="{x:Type controls:FlourishTextBlock}">
    <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeBase}" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    <Style.Triggers>
      <Trigger Property="Role" Value="Paragraph">
        <Setter Property="LineHeight" Value="{DynamicResource FlourishLineHeightBody}" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        <Setter Property="TextWrapping" Value="Wrap" />
      </Trigger>
      <Trigger Property="Role" Value="Caption">
        <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeCaption}" />
      </Trigger>
      <Trigger Property="Role" Value="Muted">
        <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeCaption}" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground2Brush}" />
      </Trigger>
      <Trigger Property="Role" Value="FieldLabel">
        <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeCaption}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground2Brush}" />
      </Trigger>
      <Trigger Property="Role" Value="Subtitle">
        <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeSubtitle}" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground2Brush}" />
        <Setter Property="LineHeight" Value="{DynamicResource FlourishLineHeightSubtitle}" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        <Setter Property="TextWrapping" Value="Wrap" />
      </Trigger>
      <Trigger Property="Role" Value="Description">
        <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeDescription}" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground2Brush}" />
        <Setter Property="LineHeight" Value="{DynamicResource FlourishLineHeightDescription}" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        <Setter Property="TextWrapping" Value="Wrap" />
      </Trigger>
      <Trigger Property="Role" Value="CardTitle">
        <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeSubtitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
      </Trigger>
      <Trigger Property="Role" Value="SectionTitle">
        <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeSectionTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
      </Trigger>
      <Trigger Property="Role" Value="PageTitle">
        <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizePageTitle}" />
        <Setter Property="FontWeight" Value="Bold" />
      </Trigger>
      <Trigger Property="Role" Value="Status">
        <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeCaption}" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishPrimaryForegroundBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
      </Trigger>
      <Trigger Property="Role" Value="Icon">
        <Setter Property="FontFamily" Value="{DynamicResource FlourishIconFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeTitlebarIcon}" />
        <Setter Property="TextAlignment" Value="Center" />
      </Trigger>
    </Style.Triggers>
  </Style>

</ResourceDictionary>
