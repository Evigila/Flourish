<Page
  x:Class="ArkheideSystem.Flourish.Controls.FlourishProfilePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:ClassModifier="internal"
  Background="Transparent"
  Focusable="False"
  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
  ScrollViewer.VerticalScrollBarVisibility="Disabled"
>
  <Page.Resources>
    <Style x:Key="ProfileTextBoxStyle" TargetType="{x:Type TextBox}">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="9,4" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="{DynamicResource FlourishSearchBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
      <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeCaption}" />
    </Style>

    <Style x:Key="ProfilePasswordBoxStyle" TargetType="{x:Type PasswordBox}">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="9,4" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="{DynamicResource FlourishSearchBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
      <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeCaption}" />
    </Style>

    <Style x:Key="ProfileActionButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="84" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="Background" Value="{DynamicResource CardSecondaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
      <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeCaption}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border
              x:Name="Chrome"
              Padding="{TemplateBinding Padding}"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="6"
            >
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter
                  TargetName="Chrome"
                  Property="Opacity"
                  Value="0.82"
                />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Opacity" Value="0.68" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style
      x:Key="ProfilePrimaryButtonStyle"
      BasedOn="{StaticResource ProfileActionButtonStyle}"
      TargetType="{x:Type Button}"
    >
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
  </Page.Resources>

  <Grid x:Name="RootGrid" Margin="22,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid Width="68" Height="68" HorizontalAlignment="Center">
      <Border
        Background="{DynamicResource FlourishProfileBackgroundBrush}"
        CornerRadius="34"
      />
      <Ellipse x:Name="AvatarImage" Visibility="Collapsed" />
      <TextBlock
        x:Name="AvatarInitials"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        FontSize="22"
        FontWeight="SemiBold"
        Foreground="{DynamicResource FlourishProfileForegroundBrush}"
      />
    </Grid>

    <StackPanel Grid.Row="1" Margin="0,10,0,0">
      <TextBlock
        x:Name="UserNameText"
        HorizontalAlignment="Center"
        FontFamily="{DynamicResource FlourishFontFamily}"
        FontSize="18"
        FontWeight="SemiBold"
        Foreground="{DynamicResource PrimaryTextBrush}"
        TextTrimming="CharacterEllipsis"
      />
      <TextBlock
        x:Name="LoginStateText"
        Margin="0,3,0,0"
        HorizontalAlignment="Center"
        FontFamily="{DynamicResource FlourishFontFamily}"
        FontSize="{DynamicResource FlourishFontSizeSmall}"
        Foreground="{DynamicResource MutedTextBrush}"
      />
    </StackPanel>

    <Grid Grid.Row="2" Margin="0,18,0,0">
      <Button
        x:Name="LoginButton"
        HorizontalAlignment="Center"
        Click="LoginButton_Click"
        Content="Sign in"
        Style="{StaticResource ProfilePrimaryButtonStyle}"
      />

      <StackPanel x:Name="LoginForm" Visibility="Collapsed">
        <TextBlock
          Margin="0,0,0,4"
          FontSize="{DynamicResource FlourishFontSizeSmall}"
          Foreground="{DynamicResource MutedTextBrush}"
          Text="User name"
        />
        <TextBox x:Name="UserNameInput" Style="{StaticResource ProfileTextBoxStyle}" />

        <TextBlock
          Margin="0,9,0,4"
          FontSize="{DynamicResource FlourishFontSizeSmall}"
          Foreground="{DynamicResource MutedTextBrush}"
          Text="Profile image"
        />
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox
            x:Name="ImagePathInput"
            IsReadOnly="True"
            Style="{StaticResource ProfileTextBoxStyle}"
          />
          <Button
            Grid.Column="1"
            Width="34"
            MinWidth="34"
            Margin="6,0,0,0"
            Click="BrowseImageButton_Click"
            Style="{StaticResource ProfileActionButtonStyle}"
            ToolTip="Choose profile image"
          >
            <TextBlock
              FontFamily="{DynamicResource FlourishIconFontFamily}"
              FontSize="15"
              Text="&#xE8B7;"
            />
          </Button>
        </Grid>

        <TextBlock
          Margin="0,9,0,4"
          FontSize="{DynamicResource FlourishFontSizeSmall}"
          Foreground="{DynamicResource MutedTextBrush}"
          Text="Password"
        />
        <PasswordBox
          x:Name="PasswordInput"
          Style="{StaticResource ProfilePasswordBoxStyle}"
        />

        <TextBlock
          x:Name="ErrorText"
          MinHeight="18"
          Margin="0,7,0,0"
          FontSize="{DynamicResource FlourishFontSizeSmall}"
          Foreground="#DC2626"
          TextWrapping="Wrap"
        />

        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
          <Button
            Margin="0,0,7,0"
            Click="CancelLoginButton_Click"
            Content="Cancel"
            Style="{StaticResource ProfileActionButtonStyle}"
          />
          <Button
            x:Name="SubmitLoginButton"
            Click="SubmitLoginButton_Click"
            Content="Sign in"
            Style="{StaticResource ProfilePrimaryButtonStyle}"
          />
        </StackPanel>
      </StackPanel>

      <StackPanel x:Name="SignedInPanel" Visibility="Collapsed">
        <CheckBox
          x:Name="RememberLoginCheckBox"
          HorizontalAlignment="Center"
          Checked="RememberLoginCheckBox_Changed"
          Content="Remember login"
          Foreground="{DynamicResource PrimaryTextBrush}"
          Unchecked="RememberLoginCheckBox_Changed"
        />
        <Button
          x:Name="LogoutButton"
          Margin="0,18,0,0"
          HorizontalAlignment="Center"
          Click="LogoutButton_Click"
          Content="Sign out"
          Style="{StaticResource ProfileActionButtonStyle}"
        />
        <TextBlock
          x:Name="SignedInErrorText"
          Margin="0,10,0,0"
          HorizontalAlignment="Center"
          FontSize="{DynamicResource FlourishFontSizeSmall}"
          Foreground="#DC2626"
          TextAlignment="Center"
          TextWrapping="Wrap"
        />
      </StackPanel>
    </Grid>
  </Grid>
</Page>
