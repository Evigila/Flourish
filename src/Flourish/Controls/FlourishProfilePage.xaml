<Page
  x:Class="ArkheideSystem.Flourish.Controls.FlourishProfilePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:ClassModifier="internal"
  Background="Transparent"
  Focusable="False"
  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
  ScrollViewer.VerticalScrollBarVisibility="Disabled"
>
  <Grid x:Name="RootGrid" Margin="16,14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Width="52" Height="52" HorizontalAlignment="Center">
      <Border
        Background="{DynamicResource FlourishProfileBackgroundBrush}"
        CornerRadius="26"
      />
      <Ellipse x:Name="AvatarImage" Visibility="Collapsed" />
      <TextBlock
        x:Name="AvatarInitials"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        FontSize="18"
        FontWeight="SemiBold"
        Foreground="{DynamicResource FlourishProfileForegroundBrush}"
      />
    </Grid>

    <StackPanel Grid.Row="1" Margin="0,8,0,0">
      <TextBlock
        x:Name="DisplayNameText"
        HorizontalAlignment="Center"
        FontFamily="{DynamicResource FlourishFontFamily}"
        FontSize="16"
        FontWeight="SemiBold"
        Foreground="{DynamicResource PrimaryTextBrush}"
        TextTrimming="CharacterEllipsis"
      />
      <TextBlock
        x:Name="LoginStateText"
        Margin="0,2,0,0"
        HorizontalAlignment="Center"
        FontFamily="{DynamicResource FlourishFontFamily}"
        FontSize="{DynamicResource FlourishFontSizeSmall}"
        Foreground="{DynamicResource MutedTextBrush}"
      />
    </StackPanel>

    <Grid Grid.Row="2" Margin="0,14,0,0">
      <Button
        x:Name="LoginButton"
        HorizontalAlignment="Center"
        Click="LoginButton_Click"
        Content="Sign in"
        Style="{StaticResource FlourishPrimaryActionButtonStyle}"
      />

      <StackPanel x:Name="LoginForm" Visibility="Collapsed">
        <Grid x:Name="NameFieldsGrid">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <StackPanel x:Name="FirstNameField" Grid.Column="0">
            <TextBlock
              Margin="0,0,0,4"
              FontSize="{DynamicResource FlourishFontSizeSmall}"
              Foreground="{DynamicResource MutedTextBrush}"
              Text="First Name"
            />
            <TextBox
              x:Name="FirstNameInput"
              Style="{StaticResource FlourishFormTextBoxStyle}"
              TextChanged="NameInput_TextChanged"
            />
          </StackPanel>

          <StackPanel x:Name="LastNameField" Grid.Column="2">
            <TextBlock
              Margin="0,0,0,4"
              FontSize="{DynamicResource FlourishFontSizeSmall}"
              Foreground="{DynamicResource MutedTextBrush}"
              Text="Last Name"
            />
            <TextBox
              x:Name="LastNameInput"
              Style="{StaticResource FlourishFormTextBoxStyle}"
              TextChanged="NameInput_TextChanged"
            />
          </StackPanel>
        </Grid>

        <TextBlock
          Margin="0,9,0,4"
          FontSize="{DynamicResource FlourishFontSizeSmall}"
          Foreground="{DynamicResource MutedTextBrush}"
          Text="Profile image"
        />
        <Button
          x:Name="UploadImageButton"
          Height="38"
          MinWidth="0"
          Padding="0"
          HorizontalAlignment="Stretch"
          HorizontalContentAlignment="Stretch"
          Click="UploadImageButton_Click"
          Style="{StaticResource FlourishActionButtonStyle}"
          ToolTip="Choose profile image"
        >
          <Grid>
            <StackPanel
              x:Name="UploadImagePrompt"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Orientation="Horizontal"
            >
              <Viewbox Width="15" Height="15" Margin="0,0,7,0">
                <Path
                  Data="M 3,16 L 3,20 L 21,20 L 21,16 M 12,3 L 12,16 M 7,8 L 12,3 L 17,8"
                  Fill="Transparent"
                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round"
                  StrokeStartLineCap="Round"
                  StrokeThickness="2"
                />
              </Viewbox>
              <TextBlock VerticalAlignment="Center" Text="Upload image" />
            </StackPanel>
            <Grid x:Name="SelectedImageContent" Visibility="Collapsed">
              <Border x:Name="SelectedImagePreview" CornerRadius="5" />
              <Border Background="#66000000" CornerRadius="5" />
              <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
              >
                <TextBlock
                  Margin="0,0,7,0"
                  FontFamily="{DynamicResource FlourishIconFontFamily}"
                  FontSize="15"
                  Foreground="White"
                  Text="&#xE73E;"
                />
                <TextBlock
                  VerticalAlignment="Center"
                  FontWeight="SemiBold"
                  Foreground="White"
                  Text="Image selected"
                />
              </StackPanel>
            </Grid>
          </Grid>
        </Button>

        <TextBlock
          Margin="0,9,0,4"
          FontSize="{DynamicResource FlourishFontSizeSmall}"
          Foreground="{DynamicResource MutedTextBrush}"
          Text="Password"
        />
        <PasswordBox
          x:Name="PasswordInput"
          Style="{StaticResource FlourishFormPasswordBoxStyle}"
        />

        <TextBlock
          x:Name="ErrorText"
          MinHeight="16"
          Margin="0,6,0,0"
          FontSize="{DynamicResource FlourishFontSizeSmall}"
          Foreground="#DC2626"
          TextWrapping="Wrap"
        />

        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
          <Button
            Margin="0,0,7,0"
            Click="CancelLoginButton_Click"
            Content="Cancel"
            Style="{StaticResource FlourishActionButtonStyle}"
          />
          <Button
            x:Name="SubmitLoginButton"
            Click="SubmitLoginButton_Click"
            Content="Sign in"
            Style="{StaticResource FlourishPrimaryActionButtonStyle}"
          />
        </StackPanel>
      </StackPanel>

      <StackPanel x:Name="SignedInPanel" Visibility="Collapsed">
        <CheckBox
          x:Name="RememberLoginCheckBox"
          HorizontalAlignment="Center"
          Checked="RememberLoginCheckBox_Changed"
          Content="Remember login"
          Style="{StaticResource FlourishCheckBoxStyle}"
          Unchecked="RememberLoginCheckBox_Changed"
        />
        <Button
          x:Name="LogoutButton"
          Margin="0,14,0,0"
          HorizontalAlignment="Center"
          Click="LogoutButton_Click"
          Content="Sign out"
          Style="{StaticResource FlourishActionButtonStyle}"
        />
        <TextBlock
          x:Name="SignedInErrorText"
          Margin="0,8,0,0"
          HorizontalAlignment="Center"
          FontSize="{DynamicResource FlourishFontSizeSmall}"
          Foreground="#DC2626"
          TextAlignment="Center"
          TextWrapping="Wrap"
        />
      </StackPanel>
    </Grid>
  </Grid>
</Page>
