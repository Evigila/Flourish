<Page
  x:Class="ArkheideSystem.Gallery.Views.CardPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:ScrollViewer
    HorizontalScrollBarVisibility="Disabled"
    VerticalScrollBarVisibility="Auto"
  >
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        ChunkHeroDescription="Use the Card family to organize information, media, settings, and append-only output."
        ChunkHeroTitle="Card"
      />

      <flourish:Chunk
        ChunkTitle="Variant"
      >
        <StackPanel>
          <UniformGrid Columns="2">
            <flourish:Card
              MinHeight="112"
              Margin="0,0,8,8"
              Text="Default surface."
              Title="Standard"
              Variant="Standard"
            />
            <flourish:Card
              MinHeight="112"
              Margin="8,0,0,8"
              Text="Quiet neutral surface."
              Title="Tonal"
              Variant="Tonal"
            />
            <flourish:Card
              MinHeight="112"
              Margin="0,8,8,0"
              Text="Primary emphasis."
              Title="Filled"
              Variant="Filled"
            />
            <flourish:Card
              MinHeight="112"
              Margin="8,8,0,0"
              Text="Raised emphasis."
              Title="Elevated"
              Variant="Elevated"
            />
          </UniformGrid>
          <flourish:Card
            Margin="0,16,0,0"
            Background="{DynamicResource FlourishSecondaryBrush}"
            Foreground="{DynamicResource FlourishForegroundOnSecondaryBrush}"
            Text="Background and Foreground override the filled palette."
            Title="Custom filled surface"
            Variant="Filled"
          />
        </StackPanel>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkTitle="Table"
      >
        <flourish:DataGrid
          x:Name="CardMemberGrid"
          AutoGenerateColumns="False"
          IsReadOnly="True"
        >
          <flourish:DataGrid.Columns>
            <DataGridTextColumn Binding="{Binding Name}" Header="Property" Width="224" />
            <DataGridTextColumn Binding="{Binding Description}" Header="Function" Width="*" />
          </flourish:DataGrid.Columns>
        </flourish:DataGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkTitle="Card"
      >
        <UniformGrid Columns="2">
            <flourish:Card
              MinHeight="160"
              Margin="0,0,8,0"
              Text="Body is optional."
              Title="Empty body"
            />
            <flourish:Card
              MinHeight="160"
              Margin="8,0,0,0"
              Text="Body accepts one object."
              Title="Arbitrary body"
            >
              <flourish:Card.Body>
                <StackPanel>
                  <ProgressBar Height="6" Maximum="100" Value="64" />
                  <flourish:FlourishTextBlock
                    Margin="0,12,0,0"
                    Role="Status"
                    Text="64% used"
                  />
                </StackPanel>
              </flourish:Card.Body>
            </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="OutputCard">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <flourish:ListCard
                Presenter="&#xE8F2;"
                Text="Append one timestamped message."
                Title="Append message"
              >
                <flourish:ListCard.Body>
                  <flourish:Button Click="AppendMessage_Click" Content="Write line" />
                </flourish:ListCard.Body>
              </flourish:ListCard>
              <flourish:ListCard
                Margin="{DynamicResource FlourishListCardPeerMargin}"
                Presenter="&#xE8FD;"
                Text="Exercise automatic viewport scrolling."
                Title="Append burst"
              >
                <flourish:ListCard.Body>
                  <flourish:Button Click="AppendBurst_Click" Content="Write 24 lines" />
                </flourish:ListCard.Body>
              </flourish:ListCard>
              <flourish:ListCard
                Margin="{DynamicResource FlourishListCardPeerMargin}"
                Presenter="&#xE946;"
                Text="Read the current Output value."
                Title="Inspect output"
              >
                <flourish:ListCard.Body>
                  <flourish:Button Click="InspectOutput_Click" Content="Write summary" />
                </flourish:ListCard.Body>
              </flourish:ListCard>
              <flourish:ListCard
                Margin="{DynamicResource FlourishListCardPeerMargin}"
                Presenter="&#xE74D;"
                Text="Reset the message history."
                Title="Clear history"
              >
                <flourish:ListCard.Body>
                  <flourish:Button Click="ClearHistory_Click" Content="Clear" Variant="Danger" />
                </flourish:ListCard.Body>
              </flourish:ListCard>
            </StackPanel>
            <flourish:OutputCard
              x:Name="HistoryOutput"
              Grid.Column="2"
              AutomationProperties.Name="Output history"
              VerticalAlignment="Stretch"
            />
          </Grid>
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="ListCard">
          <StackPanel>
            <flourish:ListCard
              Presenter="&#xE790;"
              Text="Choose a theme value."
              Title="Application theme"
            >
              <flourish:ListCard.Body>
                <flourish:FlourishComboBox Width="160" SelectedIndex="0">
                  <flourish:FlourishComboBoxItem Content="System" />
                  <flourish:FlourishComboBoxItem Content="Light" />
                  <flourish:FlourishComboBoxItem Content="Dark" />
                </flourish:FlourishComboBox>
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE838;"
              Text="Preview a local action."
              Title="Open configuration"
            >
              <flourish:ListCard.Body>
                <flourish:Button Content="Open" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE8D2;"
              Text="Edit a setting value."
              Title="Configuration key"
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox Width="200" Text="Flourish:Theme" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkTitle="Alignment"
      >
        <StackPanel>
          <UniformGrid Columns="3">
            <flourish:Card
              MinHeight="176"
              Margin="0,0,8,0"
              ContentHorizontalAlignment="Left"
              Title="Left"
            >
              <flourish:Card.Body>
                <flourish:FlourishTextBlock HorizontalAlignment="Left" Role="Status" Text="Body content" />
              </flourish:Card.Body>
            </flourish:Card>
            <flourish:Card
              MinHeight="176"
              Margin="4,0"
              ContentHorizontalAlignment="Center"
              Title="Center"
            >
              <flourish:Card.Body>
                <flourish:FlourishTextBlock HorizontalAlignment="Center" Role="Status" Text="Body content" />
              </flourish:Card.Body>
            </flourish:Card>
            <flourish:Card
              MinHeight="176"
              Margin="8,0,0,0"
              ContentHorizontalAlignment="Right"
              Title="Right"
            >
              <flourish:Card.Body>
                <flourish:FlourishTextBlock HorizontalAlignment="Right" Role="Status" Text="Body content" />
              </flourish:Card.Body>
            </flourish:Card>
          </UniformGrid>

          <UniformGrid Margin="0,16,0,0" Columns="3">
            <flourish:Card
              MinHeight="224"
              Margin="0,0,8,0"
              ContentVerticalAlignment="Top"
              Title="Top"
            >
              <flourish:Card.Body>
                <flourish:FlourishTextBlock Role="Status" Text="Body content" />
              </flourish:Card.Body>
            </flourish:Card>
            <flourish:Card
              MinHeight="224"
              Margin="4,0"
              ContentHorizontalAlignment="Center"
              ContentVerticalAlignment="Center"
              Title="Center"
            >
              <flourish:Card.Body>
                <flourish:FlourishTextBlock Role="Status" Text="Body content" />
              </flourish:Card.Body>
            </flourish:Card>
            <flourish:Card
              MinHeight="224"
              Margin="8,0,0,0"
              ContentVerticalAlignment="Bottom"
              Title="Bottom"
            >
              <flourish:Card.Body>
                <flourish:FlourishTextBlock Role="Status" Text="Body content" />
              </flourish:Card.Body>
            </flourish:Card>
          </UniformGrid>

        </StackPanel>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkTitle="IconCard"
      >
          <UniformGrid Columns="2">
            <flourish:IconCard
              MinHeight="184"
              Margin="0,0,8,8"
              Presenter="&#xE8A5;"
              PresenterPosition="Top"
              Title="Top presenter"
            >
              <flourish:IconCard.Body>
                <flourish:FlourishTextBlock Role="Status" Text="Body content" />
              </flourish:IconCard.Body>
            </flourish:IconCard>
            <flourish:IconCard
              MinHeight="184"
              Margin="8,0,0,8"
              Presenter="&#xE8A5;"
              PresenterPosition="Left"
              Title="Left presenter"
            >
              <flourish:IconCard.Body>
                <flourish:FlourishTextBlock Role="Status" Text="Body content" />
              </flourish:IconCard.Body>
            </flourish:IconCard>
            <flourish:IconCard
              MinHeight="184"
              Margin="0,8,8,0"
              Presenter="&#xE8A5;"
              PresenterPosition="RightBottom"
              Title="Right-bottom presenter"
            >
              <flourish:IconCard.Body>
                <flourish:FlourishTextBlock Role="Status" Text="Body content" />
              </flourish:IconCard.Body>
            </flourish:IconCard>
            <flourish:IconCard
              MinHeight="184"
              Margin="8,8,0,0"
              PresenterMode="Overlay"
              Text="Presenter fills the surface."
              Title="Overlay presenter"
            >
              <flourish:IconCard.Presenter>
                <Border>
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                      <GradientStop Offset="0" Color="#0F6CBD" />
                      <GradientStop Offset="1" Color="#5C2E91" />
                    </LinearGradientBrush>
                  </Border.Background>
                  <flourish:FlourishTextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="{DynamicResource FlourishIconFontFamily}"
                    FontSize="{DynamicResource FlourishFontSizeIcon}"
                    Foreground="#80FFFFFF"
                    Role="Icon"
                    Text="&#xE8A5;"
                  />
                </Border>
              </flourish:IconCard.Presenter>
              <flourish:IconCard.Body>
                <flourish:FlourishTextBlock Role="Status" Text="Body content" />
              </flourish:IconCard.Body>
            </flourish:IconCard>
          </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkTitle="Usage"
      >
        <StackPanel>
          <flourish:FlourishTextBlock
            Role="Description"
            Text="Set Title and Text in XAML, then place one object or layout container in Body."
            TextWrapping="Wrap"
          />
          <flourish:FlourishTextBlock
            Margin="0,8,0,0"
            Role="Description"
            Text="Append OutputCard history with WriteLine and reset it only through an explicit Clear action."
            TextWrapping="Wrap"
          />
          <flourish:FlourishTextBlock
            Margin="0,8,0,0"
            Role="Description"
            Text="Bind controls placed in Body to application state; use CardButton when the entire surface invokes a command."
            TextWrapping="Wrap"
          />
        </StackPanel>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkTitle="Reference"
      >
        <UniformGrid Columns="2">
          <flourish:CardButton
            Margin="0,0,8,0"
            AutomationProperties.Name="Flourish GitHub repository"
            Content="Repository link placeholder"
            Icon="&#xE943;"
            IsEnabled="False"
            Title="GitHub repository"
            ToolTip="External navigation is not available in Gallery."
          />
          <flourish:CardButton
            Margin="8,0,0,0"
            AutomationProperties.Name="Card documentation"
            Content="Canonical documentation link placeholder"
            Icon="&#xE8A5;"
            IsEnabled="False"
            Title="Card documentation"
            ToolTip="External navigation is not available in Gallery."
          />
        </UniformGrid>
      </flourish:Chunk>
    </StackPanel>
  </flourish:ScrollViewer>
</Page>
