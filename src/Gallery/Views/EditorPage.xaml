<Page
  x:Class="ArkheideSystem.Gallery.Views.EditorPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Background="Transparent"
  mc:Ignorable="d"
>
  <Grid>
    <StackPanel Width="520" HorizontalAlignment="Center" VerticalAlignment="Center">
      <flourish:FlourishTextBlock
        HorizontalAlignment="Center"
        FontFamily="Segoe MDL2 Assets"
        FontSize="42"
        Foreground="{DynamicResource FlourishPrimaryForegroundBrush}"
        Text="&#xE70F;"
      />
      <flourish:FlourishTextBlock
        Margin="0,12,0,0"
        HorizontalAlignment="Center"
        Role="PageTitle"
        Text="编辑"
      />
      <flourish:FlourishTextBlock
        Margin="0,10,0,0"
        HorizontalAlignment="Center"
        Role="Subtitle"
        Text="这里是编辑页面占位内容，后续可用于承载图片裁剪、滤镜和标注工具。"
        TextAlignment="Center"
        TextWrapping="Wrap"
      />
    </StackPanel>
  </Grid>
</Page>
