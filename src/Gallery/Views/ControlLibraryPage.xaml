<Page
  x:Class="ArkheideSystem.Gallery.Views.ControlLibraryPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="0,28,0,40">
      <flourish:FlourishTextBlock Role="PageTitle" Text="Control library" />
      <flourish:FlourishTextBlock
        Role="Subtitle"
        Text="Reusable Flourish controls share compact metrics, semantic colors, keyboard focus, and runtime theme and font resources."
      />

      <flourish:FlourishCard Margin="0,24,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Button appearances" />
          <flourish:FlourishTextBlock
            Margin="0,5,0,14"
            Role="Muted"
            Text="The appearance property selects emphasis without a page-local Style."
          />
          <WrapPanel>
            <flourish:FlourishButton Margin="0,0,8,8" Appearance="Standard" Content="Standard" />
            <flourish:FlourishButton Margin="0,0,8,8" Appearance="Primary" Content="Primary" />
            <flourish:FlourishButton Margin="0,0,8,8" Appearance="Subtle" Content="Subtle" />
            <flourish:FlourishButton Margin="0,0,8,8" Appearance="Card" Content="Card action" />
          </WrapPanel>
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Typography roles" />
          <UniformGrid Margin="0,14,0,0" Columns="3">
            <flourish:FlourishTextBlock Margin="0,0,16,10" Role="Body" Text="Body — regular content" />
            <flourish:FlourishTextBlock Margin="0,0,16,10" Role="Caption" Text="Caption — compact detail" />
            <flourish:FlourishTextBlock Margin="0,0,16,10" Role="Muted" Text="Muted — secondary detail" />
            <flourish:FlourishTextBlock Margin="0,0,16,10" Role="FieldLabel" Text="FIELD LABEL" />
            <flourish:FlourishTextBlock Margin="0,0,16,10" Role="Subtitle" Text="Subtitle — supporting heading" />
            <flourish:FlourishTextBlock Margin="0,0,16,10" Role="SectionTitle" Text="Section title" />
            <flourish:FlourishTextBlock Margin="0,0,16,10" Role="PageTitle" Text="Page title" />
            <flourish:FlourishTextBlock Margin="0,0,16,10" Role="Status" Text="Status — ready" />
            <flourish:FlourishTextBlock Margin="0,0,16,10" Role="Icon" Text="&#xE8D2;" />
          </UniformGrid>
        </StackPanel>
      </flourish:FlourishCard>

      <Grid Margin="0,16,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <flourish:FlourishCard>
          <StackPanel>
            <flourish:FlourishTextBlock Role="SectionTitle" Text="Inputs and selection" />

            <flourish:FlourishLabel Margin="0,14,0,5" Content="_Text box" Target="{Binding ElementName=ControlTextBox}" />
            <flourish:FlourishTextBox x:Name="ControlTextBox" Text="Editable text" />

            <flourish:FlourishTextBlock Margin="0,12,0,5" Role="FieldLabel" Text="PASSWORD BOX" />
            <flourish:FlourishPasswordBox Password="Flourish" />

            <flourish:FlourishTextBlock Margin="0,12,0,5" Role="FieldLabel" Text="SEARCH BOX" />
            <flourish:FlourishSearchBox Placeholder="Search controls" />

            <flourish:FlourishCheckBox Margin="0,14,0,0" Content="Use compact Fluent controls" IsChecked="True" />

            <flourish:FlourishTextBlock Margin="0,14,0,5" Role="FieldLabel" Text="RADIO BUTTON" />
            <StackPanel Orientation="Horizontal">
              <flourish:FlourishRadioButton
                Margin="0,0,14,0"
                Content="Automatic"
                GroupName="ControlDensity"
                IsChecked="True"
              />
              <flourish:FlourishRadioButton Content="Manual" GroupName="ControlDensity" />
            </StackPanel>

            <flourish:FlourishTextBlock Margin="0,14,0,5" Role="FieldLabel" Text="COMBO BOX" />
            <flourish:FlourishComboBox SelectedIndex="0">
              <flourish:FlourishComboBoxItem Content="Standard density" />
              <flourish:FlourishComboBoxItem Content="Compact density" />
              <flourish:FlourishComboBoxItem Content="Comfortable density" />
            </flourish:FlourishComboBox>
          </StackPanel>
        </flourish:FlourishCard>

        <flourish:FlourishCard Grid.Column="2">
          <StackPanel>
            <flourish:FlourishTextBlock Role="SectionTitle" Text="Lists and scrolling" />

            <flourish:FlourishTextBlock Margin="0,14,0,5" Role="FieldLabel" Text="LIST BOX" />
            <flourish:FlourishListBox Height="104" SelectedIndex="0">
              <flourish:FlourishListBoxItem Content="Button and typography" />
              <flourish:FlourishListBoxItem Content="Inputs and selection" />
              <flourish:FlourishListBoxItem Content="Scrolling and surfaces" />
            </flourish:FlourishListBox>

            <flourish:FlourishTextBlock Margin="0,14,0,5" Role="FieldLabel" Text="SCROLL VIEWER" />
            <flourish:FlourishScrollViewer Height="104" VerticalScrollBarVisibility="Auto">
              <StackPanel>
                <flourish:FlourishTextBlock Margin="8,6" Text="A compact scrolling surface" />
                <flourish:FlourishTextBlock Margin="8,6" Role="Muted" Text="Scrollbars use the same state tokens." />
                <flourish:FlourishTextBlock Margin="8,6" Text="Keyboard and wheel input remain native." />
                <flourish:FlourishTextBlock Margin="8,6" Role="Status" Text="End of sample" />
              </StackPanel>
            </flourish:FlourishScrollViewer>
          </StackPanel>
        </flourish:FlourishCard>
      </Grid>

      <UniformGrid Margin="0,16,0,0" Columns="3">
        <flourish:FlourishCard Margin="0,0,8,0" Appearance="Standard">
          <flourish:FlourishTextBlock Text="Standard card" />
        </flourish:FlourishCard>
        <flourish:FlourishCard Margin="4,0" Appearance="Subtle">
          <flourish:FlourishTextBlock Text="Subtle card" />
        </flourish:FlourishCard>
        <flourish:FlourishCard Margin="8,0,0,0" Appearance="Accent">
          <flourish:FlourishTextBlock Text="Accent card" />
        </flourish:FlourishCard>
      </UniformGrid>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
