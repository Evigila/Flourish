<Page
  x:Class="ArkheideSystem.Gallery.Views.ButtonPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:ScrollViewer
    HorizontalScrollBarVisibility="Disabled"
    VerticalScrollBarVisibility="Auto"
  >
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        ChunkHeroDescription="Accessible application actions built on the WPF button contract."
        ChunkHeroTitle="Button"
      />

      <flourish:Chunk ChunkTitle="Variant">
        <UniformGrid Columns="2">
          <flourish:Card Margin="0,0,8,0">
            <flourish:Card.Body>
              <WrapPanel>
                <flourish:Button Margin="0,0,8,8" Content="Elevated" Variant="Elevated" />
                <flourish:Button Margin="0,0,8,8" Content="Filled" Variant="Filled" />
                <flourish:Button Margin="0,0,8,8" Content="Tonal" Variant="Tonal" />
                <flourish:Button Margin="0,0,8,8" Content="Outlined" Variant="Outlined" />
                <flourish:Button Margin="0,0,8,8" Content="Text" Variant="Text" />
                <flourish:Button Margin="0,0,0,8" Content="Danger" Variant="Danger" />
              </WrapPanel>
            </flourish:Card.Body>
          </flourish:Card>
          <flourish:Card
            Margin="8,0,0,0"
            Text="Filled is primary, Tonal is softer, and Danger identifies destructive intent."
            Title="Visual hierarchy"
          />
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="Table">
        <flourish:DataGrid
          x:Name="PropertiesGrid"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          CanUserReorderColumns="False"
          FontWeight="Regular"
          IsReadOnly="True"
        >
          <flourish:DataGrid.Columns>
            <DataGridTextColumn
              Binding="{Binding Name}"
              Header="PROPERTY"
              Width="220"
            />
            <DataGridTextColumn
              Binding="{Binding Description}"
              Header="PURPOSE"
              Width="*"
            />
          </flourish:DataGrid.Columns>
        </flourish:DataGrid>
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="Button">
        <UniformGrid Columns="2">
          <flourish:Card Margin="0,0,8,0">
            <flourish:Card.Body>
              <WrapPanel>
                <flourish:Button Margin="0,0,8,0" Content="Continue" Variant="Filled" />
                <flourish:Button Content="Cancel" Variant="Outlined" />
              </WrapPanel>
            </flourish:Card.Body>
          </flourish:Card>
          <flourish:Card
            Margin="8,0,0,0"
            Text="Bind Command for reusable actions, or handle Click for local behavior."
            Title="Standard action"
          />
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="IconButton">
        <UniformGrid Columns="2">
          <flourish:Card Margin="0,0,8,0">
            <flourish:Card.Body>
              <WrapPanel>
                <flourish:IconButton
                  Margin="0,0,8,0"
                  Icon="&#xE72C;"
                  ToolTip="Refresh"
                  Variant="Text"
                />
                <flourish:IconButton
                  Margin="0,0,8,0"
                  Icon="&#xE8D4;"
                  ToolTip="Search"
                  Variant="Text"
                />
                <flourish:IconButton Content="Add item" Icon="&#xE710;" Variant="Filled" />
              </WrapPanel>
            </flourish:Card.Body>
          </flourish:Card>
          <flourish:Card
            Margin="8,0,0,0"
            Text="Use a ToolTip or automation name when the action has no visible label."
            Title="Icon actions"
          />
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="CardButton">
        <UniformGrid Columns="2">
          <flourish:CardButton
            Margin="0,0,8,0"
            Content="Review generated reports."
            Icon="&#xE8A5;"
            Title="Open reports"
          />
          <flourish:CardButton
            Margin="8,0,0,0"
            Content="Use a compact horizontal layout."
            Icon="&#xE946;"
            IconPosition="Left"
            Title="View details"
          />
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="WindowCaptionButton">
        <UniformGrid Columns="2">
          <flourish:Card Margin="0,0,8,0">
            <flourish:Card.Body>
              <Border
                HorizontalAlignment="Left"
                Background="{DynamicResource FlourishControlBackgroundBrush}"
                BorderBrush="{DynamicResource FlourishControlStrokeBrush}"
                BorderThickness="1"
              >
                <StackPanel Orientation="Horizontal">
                  <flourish:WindowCaptionButton Icon="&#xE921;" ToolTip="Minimize" Variant="Text" />
                  <flourish:WindowCaptionButton Icon="&#xE922;" ToolTip="Maximize" Variant="Text" />
                  <flourish:WindowCaptionButton Icon="&#xE8BB;" ToolTip="Close" Variant="Danger" />
                </StackPanel>
              </Border>
            </flourish:Card.Body>
          </flourish:Card>
          <flourish:Card
            Margin="8,0,0,0"
            Text="Use dedicated title-bar geometry and reserve Danger for close."
            Title="Caption actions"
          />
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="Hover feedback">
        <UniformGrid Columns="2">
          <flourish:Card Margin="0,0,8,0">
            <flourish:Card.Body>
              <WrapPanel>
                <flourish:Button Margin="0,0,8,0" Content="Default reveal" />
                <flourish:Button flourish:HoverReveal.IsEnabled="False" Content="Static feedback" />
              </WrapPanel>
            </flourish:Card.Body>
          </flourish:Card>
          <flourish:Card
            Margin="8,0,0,0"
            Text="HoverReveal supplies feedback and can be disabled for a local action."
            Title="Pointer feedback"
          />
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="Interaction contract">
        <flourish:FlourishTextBlock
          Text="Every button type retains focus, keyboard activation, commands, disabled state, and automation behavior."
          TextWrapping="Wrap"
        />
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="Usage">
        <StackPanel>
          <flourish:FlourishTextBlock
            Text="Handle Click for local behavior or bind Command and CommandParameter when the application owns the action."
            TextWrapping="Wrap"
          />
          <flourish:FlourishTextBlock
            Margin="0,8,0,0"
            Role="Muted"
            Text="Use CardButton for an interactive card surface; Card remains display-only."
            TextWrapping="Wrap"
          />
        </StackPanel>
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="Reference">
        <UniformGrid Columns="2">
          <flourish:CardButton
            Margin="0,0,8,0"
            AutomationProperties.Name="Flourish GitHub repository"
            Content="Repository link placeholder"
            Icon="&#xE943;"
            IsEnabled="False"
            Title="GitHub repository"
            ToolTip="External navigation is not available in Gallery."
          />
          <flourish:CardButton
            Margin="8,0,0,0"
            AutomationProperties.Name="Button documentation"
            Content="Canonical documentation link placeholder"
            Icon="&#xE8A5;"
            IsEnabled="False"
            Title="Button documentation"
            ToolTip="External navigation is not available in Gallery."
          />
        </UniformGrid>
      </flourish:Chunk>
    </StackPanel>
  </flourish:ScrollViewer>
</Page>
