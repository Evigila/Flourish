<Page
  x:Class="ArkheideSystem.Gallery.Views.HomePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:FlourishCard Appearance="Hero">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <flourish:FlourishTextBlock Role="PageTitle" Text="Flourish Gallery" />
            <flourish:FlourishTextBlock
              Margin="{DynamicResource FlourishPageSubtitleMargin}"
              Role="Subtitle"
              MaxWidth="720"
              Text="Every page calls Flourish APIs directly. Change configuration, appearance, navigation, shell surfaces, commands, window behavior, and background work without restarting the application."
            />
          </StackPanel>
          <flourish:FlourishTextBlock
            Grid.Column="1"
            Margin="24,0,0,0"
            VerticalAlignment="Center"
            FontFamily="{DynamicResource FlourishIconFontFamily}"
            FontSize="48"
            Foreground="{DynamicResource FlourishAccentForegroundBrush}"
            Text="&#xE950;"
          />
        </Grid>
      </flourish:FlourishCard>

      <StackPanel Margin="{DynamicResource FlourishSectionMargin}">
        <flourish:FlourishTextBlock Role="SectionTitle" Text="Demos" />
        <flourish:FlourishTextBlock
          Margin="{DynamicResource FlourishSectionDescriptionMargin}"
          Role="Description"
          Text="Explore the public APIs by capability. Interactive cards resize with the available page width."
        />

        <UniformGrid
          x:Name="DemoGrid"
          Margin="0,6,-6,-6"
          Columns="3"
          SizeChanged="DemoGrid_SizeChanged"
        >
        <flourish:FlourishButton Appearance="Card"
          MinHeight="150"
          Margin="6"
          AutomationProperties.Name="Configuration and locale"
          Click="DemoCard_Click"
          Tag="Configuration"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishPrimaryForegroundBrush}"
                Text="&#xE713;"
              />
              <flourish:FlourishTextBlock
                Margin="0,12,0,0"
                Role="CardTitle"
                Text="Configuration &amp; locale"
              />
              <flourish:FlourishTextBlock
                Margin="0,4,0,0"
                Role="Description"
                Text="Read, edit, append, save, reload, and switch locale."
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          MinHeight="150"
          Margin="6"
          AutomationProperties.Name="Appearance and motion"
          Click="DemoCard_Click"
          Tag="Appearance"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishSecondaryForegroundBrush}"
                Text="&#xE790;"
              />
              <flourish:FlourishTextBlock Margin="0,12,0,0" Role="CardTitle" Text="Appearance &amp; motion" />
              <flourish:FlourishTextBlock
                Margin="0,4,0,0"
                Role="Description"
                Text="Theme, fonts, tooltips, animation, and material effects."
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          MinHeight="150"
          Margin="6"
          AutomationProperties.Name="Title bar and search"
          Click="DemoCard_Click"
          Tag="TitleBarRuntime"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishAccentForegroundBrush}"
                Text="&#xE8A4;"
              />
              <flourish:FlourishTextBlock Margin="0,12,0,0" Role="CardTitle" Text="Title bar &amp; search" />
              <flourish:FlourishTextBlock
                Margin="0,4,0,0"
                Role="Description"
                Text="Identity, element visibility, shell features, and search handlers."
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          MinHeight="150"
          Margin="6"
          AutomationProperties.Name="Navigation"
          Click="DemoCard_Click"
          Tag="NavigationRuntime"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishPrimaryForegroundBrush}"
                Text="&#xE700;"
              />
              <flourish:FlourishTextBlock Margin="0,12,0,0" Role="CardTitle" Text="Navigation" />
              <flourish:FlourishTextBlock
                Margin="0,4,0,0"
                Role="Description"
                Text="Panel placement, sizing, routes, cache, and menu items."
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          MinHeight="150"
          Margin="6"
          AutomationProperties.Name="Toolbar and status"
          Click="DemoCard_Click"
          Tag="ToolbarStatus"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishSecondaryForegroundBrush}"
                Text="&#xE945;"
              />
              <flourish:FlourishTextBlock Margin="0,12,0,0" Role="CardTitle" Text="Toolbar &amp; status" />
              <flourish:FlourishTextBlock
                Margin="0,4,0,0"
                Role="Description"
                Text="Dynamic actions, status messages, and custom shell regions."
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          MinHeight="150"
          Margin="6"
          AutomationProperties.Name="Commands and shortcuts"
          Click="DemoCard_Click"
          Tag="Commands"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishAccentForegroundBrush}"
                Text="&#xE756;"
              />
              <flourish:FlourishTextBlock Margin="0,12,0,0" Role="CardTitle" Text="Commands &amp; shortcuts" />
              <flourish:FlourishTextBlock
                Margin="0,4,0,0"
                Role="Description"
                Text="Register, dispatch, disable, remove, and bind keyboard input."
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          MinHeight="150"
          Margin="6"
          AutomationProperties.Name="Window and profile"
          Click="DemoCard_Click"
          Tag="WindowRuntime"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishPrimaryForegroundBrush}"
                Text="&#xE737;"
              />
              <flourish:FlourishTextBlock Margin="0,12,0,0" Role="CardTitle" Text="Window &amp; profile" />
              <flourish:FlourishTextBlock
                Margin="0,4,0,0"
                Role="Description"
                Text="Window, tray, close guards, profile, dialogs, and notifications."
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          MinHeight="150"
          Margin="6"
          AutomationProperties.Name="Background tasks"
          Click="DemoCard_Click"
          Tag="BackgroundTasks"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishSecondaryForegroundBrush}"
                Text="&#xE895;"
              />
              <flourish:FlourishTextBlock Margin="0,12,0,0" Role="CardTitle" Text="Background tasks" />
              <flourish:FlourishTextBlock
                Margin="0,4,0,0"
                Role="Description"
                Text="Queue work, observe progress, cancel, and capture results."
              />
          </StackPanel>
        </flourish:FlourishButton>
        </UniformGrid>
      </StackPanel>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
