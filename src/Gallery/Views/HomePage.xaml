<Page
  x:Class="ArkheideSystem.Gallery.Views.HomePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="0,28,0,40">
      <flourish:FlourishCard Appearance="Accent" Padding="28">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <flourish:FlourishTextBlock Role="PageTitle" Text="Flourish Gallery" />
            <flourish:FlourishTextBlock Role="Subtitle"
              MaxWidth="720"
              Text="Every page calls Flourish APIs directly. Change configuration, appearance, navigation, shell surfaces, commands, window behavior, and background work without restarting the application."
            />
          </StackPanel>
          <flourish:FlourishTextBlock
            Grid.Column="1"
            Margin="24,0,0,0"
            VerticalAlignment="Center"
            FontFamily="{DynamicResource FlourishIconFontFamily}"
            FontSize="48"
            Foreground="{DynamicResource FlourishBrandForegroundBrush}"
            Text="&#xE950;"
          />
        </Grid>
      </flourish:FlourishCard>

      <flourish:FlourishTextBlock Role="SectionTitle"
        Margin="0,28,0,14"
        Text="Demos"
      />

      <WrapPanel ItemHeight="154" ItemWidth="250">
        <flourish:FlourishButton Appearance="Card"
          Width="232"
          Height="136"
          Margin="0,0,14,14"
          Click="DemoCard_Click"
          Tag="Configuration"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishBrandForegroundBrush}"
                Text="&#xE713;"
              />
              <flourish:FlourishTextBlock
                Margin="0,10,0,0"
                FontWeight="SemiBold"
                Text="Configuration &amp; locale"
              />
              <flourish:FlourishTextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
                Text="Read, edit, append, save, reload, and switch locale."
                TextWrapping="Wrap"
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          Width="232"
          Height="136"
          Margin="0,0,14,14"
          Click="DemoCard_Click"
          Tag="Appearance"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishBrandForegroundBrush}"
                Text="&#xE790;"
              />
              <flourish:FlourishTextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Appearance &amp; motion" />
              <flourish:FlourishTextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
                Text="Theme, fonts, tooltips, animation, and material effects."
                TextWrapping="Wrap"
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          Width="232"
          Height="136"
          Margin="0,0,14,14"
          Click="DemoCard_Click"
          Tag="TitleBarRuntime"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishBrandForegroundBrush}"
                Text="&#xE8A4;"
              />
              <flourish:FlourishTextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Title bar &amp; search" />
              <flourish:FlourishTextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
                Text="Identity, element visibility, shell features, and search handlers."
                TextWrapping="Wrap"
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          Width="232"
          Height="136"
          Margin="0,0,14,14"
          Click="DemoCard_Click"
          Tag="NavigationRuntime"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishBrandForegroundBrush}"
                Text="&#xE700;"
              />
              <flourish:FlourishTextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Navigation" />
              <flourish:FlourishTextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
                Text="Panel placement, sizing, routes, cache, and menu items."
                TextWrapping="Wrap"
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          Width="232"
          Height="136"
          Margin="0,0,14,14"
          Click="DemoCard_Click"
          Tag="ToolbarStatus"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishBrandForegroundBrush}"
                Text="&#xE945;"
              />
              <flourish:FlourishTextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Toolbar &amp; status" />
              <flourish:FlourishTextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
                Text="Dynamic actions, status messages, and custom shell regions."
                TextWrapping="Wrap"
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          Width="232"
          Height="136"
          Margin="0,0,14,14"
          Click="DemoCard_Click"
          Tag="Commands"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishBrandForegroundBrush}"
                Text="&#xE756;"
              />
              <flourish:FlourishTextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Commands &amp; shortcuts" />
              <flourish:FlourishTextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
                Text="Register, dispatch, disable, remove, and bind keyboard input."
                TextWrapping="Wrap"
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          Width="232"
          Height="136"
          Margin="0,0,14,14"
          Click="DemoCard_Click"
          Tag="WindowRuntime"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishBrandForegroundBrush}"
                Text="&#xE737;"
              />
              <flourish:FlourishTextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Window &amp; profile" />
              <flourish:FlourishTextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
                Text="Window, tray, close guards, profile, dialogs, and notifications."
                TextWrapping="Wrap"
              />
          </StackPanel>
        </flourish:FlourishButton>

        <flourish:FlourishButton Appearance="Card"
          Width="232"
          Height="136"
          Margin="0,0,14,14"
          Click="DemoCard_Click"
          Tag="BackgroundTasks"
        >
          <StackPanel>
              <flourish:FlourishTextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource FlourishBrandForegroundBrush}"
                Text="&#xE895;"
              />
              <flourish:FlourishTextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Background tasks" />
              <flourish:FlourishTextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
                Text="Queue work, observe progress, cancel, and capture results."
                TextWrapping="Wrap"
              />
          </StackPanel>
        </flourish:FlourishButton>
      </WrapPanel>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
