<Page
  x:Class="ArkheideSystem.Gallery.Views.BackgroundTasksPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="0,28,0,40">
      <flourish:FlourishTextBlock Role="PageTitle" Text="Background tasks" />
      <flourish:FlourishTextBlock Role="Subtitle"
        Text="Submit work after startup, observe immutable progress snapshots, request cooperative cancellation, and await captured outcomes without crashing the host."
      />

      <flourish:FlourishCard Margin="0,24,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Queue runtime work" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Progress tasks report twenty updates. Result tasks return a value. A burst demonstrates the service's bounded concurrency." TextWrapping="Wrap" />
          <WrapPanel>
            <flourish:FlourishButton Margin="0,0,8,8" Click="AddProgressTask_Click" Content="Add progress task" />
            <flourish:FlourishButton Margin="0,0,8,8" Click="AddResultTask_Click" Content="Add result task" />
            <flourish:FlourishButton Margin="0,0,8,8" Click="AddBurst_Click" Content="Queue 4 tasks" />
            <flourish:FlourishButton Margin="0,0,8,8" Click="CancelLast_Click" Content="Cancel last" />
            <flourish:FlourishButton Margin="0,0,8,8" Click="CancelSelected_Click" Content="Cancel selected" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="ServiceStatusText" Margin="0,6,0,0" Foreground="{DynamicResource FlourishBrandForegroundBrush}" />
        </StackPanel>
      </flourish:FlourishCard>

      <Grid Margin="0,16,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.2*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <flourish:FlourishCard Margin="0,0,8,0">
          <StackPanel>
            <flourish:FlourishTextBlock Role="SectionTitle" Text="Active queue" />
            <flourish:FlourishTextBlock Margin="0,5,0,12" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Queued, running, and cancelling items update through TasksChanged." TextWrapping="Wrap" />
            <flourish:FlourishListBox x:Name="ActiveTaskList" MinHeight="220" />
          </StackPanel>
        </flourish:FlourishCard>

        <flourish:FlourishCard Grid.Column="1" Margin="8,0,0,0">
          <StackPanel>
            <flourish:FlourishTextBlock Role="SectionTitle" Text="Captured outcomes" />
            <flourish:FlourishTextBlock Margin="0,5,0,12" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Completion never faults; failures and cancellation are represented in the result object." TextWrapping="Wrap" />
            <flourish:FlourishListBox x:Name="OutcomeList" MinHeight="220" />
          </StackPanel>
        </flourish:FlourishCard>
      </Grid>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
