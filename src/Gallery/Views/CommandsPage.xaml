<Page
  x:Class="ArkheideSystem.Gallery.Views.CommandsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:FlourishTextBlock Role="PageTitle" Text="Commands &amp; shortcuts" />
      <flourish:FlourishTextBlock Role="Subtitle"
        Margin="{DynamicResource FlourishPageSubtitleMargin}"
        Text="Register application logic after startup, change its availability, dispatch it asynchronously, and bind the same command to a runtime keyboard shortcut."
      />

      <StackPanel Margin="{DynamicResource FlourishSectionMargin}">
        <flourish:FlourishTextBlock Role="SectionTitle" Text="Runtime command registration" />
        <flourish:FlourishTextBlock
          Margin="{DynamicResource FlourishSectionDescriptionMargin}"
          Role="Description"
          Text="The demo handler waits briefly, increments an execution counter, and returns a value through CommandResult."
          TextWrapping="Wrap"
        />
        <flourish:FlourishCard Margin="{DynamicResource FlourishSectionCardMargin}">
          <StackPanel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Command key" />
              <flourish:FlourishTextBox x:Name="CommandKeyBox" Text="gallery.runtime.greet" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Dispatch parameter" />
              <flourish:FlourishTextBox x:Name="CommandParameterBox" Text="Flourish user" />
            </StackPanel>
          </Grid>
          <WrapPanel Margin="0,14,0,0">
            <flourish:FlourishButton Margin="0,0,8,0" Click="RegisterCommand_Click" Content="Register / replace" />
            <flourish:FlourishButton Margin="0,0,8,0" Click="ExecuteCommand_Click" Content="Execute async" />
            <flourish:FlourishButton Margin="0,0,8,0" Click="RemoveCommand_Click" Content="Remove command" />
            <flourish:FlourishCheckBox x:Name="CommandEnabledBox" Margin="12,0,8,0" VerticalAlignment="Center" IsChecked="True" Content="Can execute" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="CommandResultText" Margin="0,12,0,0" Role="Status" Text="Register the demo command to begin." />
          </StackPanel>
        </flourish:FlourishCard>
      </StackPanel>

      <StackPanel Margin="{DynamicResource FlourishSectionMargin}">
        <flourish:FlourishTextBlock Role="SectionTitle" Text="Keyboard shortcut" />
        <flourish:FlourishTextBlock
          Margin="{DynamicResource FlourishSectionDescriptionMargin}"
          Role="Description"
          Text="Bind Ctrl+Shift+G to the command key above. The shell can resolve and dispatch it globally; the button invokes the same shortcut API directly for a deterministic demo."
          TextWrapping="Wrap"
        />
        <flourish:FlourishCard Margin="{DynamicResource FlourishSectionCardMargin}">
          <StackPanel>
          <WrapPanel>
            <flourish:FlourishButton Margin="0,0,8,0" Click="RegisterShortcut_Click" Content="Register Ctrl+Shift+G" />
            <flourish:FlourishButton Margin="0,0,8,0" Click="ExecuteShortcut_Click" Content="Dispatch shortcut" />
            <flourish:FlourishButton Click="RemoveShortcut_Click" Content="Remove shortcut" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="ShortcutResultText" Margin="0,12,0,0" Role="Description" Text="No shortcut registered by this page." />
          </StackPanel>
        </flourish:FlourishCard>
      </StackPanel>

      <StackPanel Margin="{DynamicResource FlourishSectionMargin}">
        <flourish:FlourishTextBlock Role="SectionTitle" Text="Registry snapshots" />
        <flourish:FlourishTextBlock
          Margin="{DynamicResource FlourishSectionDescriptionMargin}"
          Role="Description"
          Text="Both registries expose immutable snapshots and change events for diagnostic or management UIs."
        />
        <flourish:FlourishCard Margin="{DynamicResource FlourishSectionCardMargin}">
          <StackPanel>
          <flourish:FlourishTextBlock x:Name="RegistrySummaryText" Role="Status" />
          <flourish:FlourishListBox x:Name="RegistryList" MinHeight="90" MaxHeight="220" Margin="0,10,0,0" />
          </StackPanel>
        </flourish:FlourishCard>
      </StackPanel>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
