<Page
  x:Class="ArkheideSystem.Gallery.Views.ToolbarStatusPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="0,28,0,40">
      <flourish:FlourishTextBlock Role="PageTitle" Text="Toolbar, status and shell regions" />
      <flourish:FlourishTextBlock Role="Subtitle"
        Text="Every control below edits a live shell surface. Stable IDs make add, update, move, enable, hide and remove operations deterministic."
      />

      <flourish:FlourishCard Margin="0,24,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Dynamic toolbar" />
          <flourish:FlourishTextBlock Margin="0,7,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Add an action for this page, then use the actual shell toolbar button above the page to execute the runtime command." TextWrapping="Wrap" />
          <WrapPanel Margin="0,14,0,0">
            <flourish:FlourishButton Click="AddToolbarItem_Click" Content="Add / update action" />
            <flourish:FlourishButton Margin="8,0,0,0" Click="ToggleToolbarItemEnabled_Click" Content="Enable / disable" />
            <flourish:FlourishButton Margin="8,0,0,0" Click="ToggleToolbarItemVisible_Click" Content="Show / hide" />
            <flourish:FlourishButton Margin="8,0,0,0" Click="ToggleIconOnly_Click" Content="Icon / icon + text" />
            <flourish:FlourishButton Margin="8,0,0,0" Click="MoveToolbarItem_Click" Content="Move action" />
            <flourish:FlourishButton Margin="8,0,0,0" Click="RemoveToolbarItem_Click" Content="Remove" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="ToolbarStateText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" TextWrapping="Wrap" />
          <flourish:FlourishTextBlock x:Name="CommandLogText" Margin="0,8,0,0" FontFamily="Consolas" Foreground="{DynamicResource FlourishBrandForegroundBrush}" Text="The toolbar command has not run yet." TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Status bar" />
          <WrapPanel Margin="0,14,0,0">
            <StackPanel Margin="0,0,10,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Status text" />
              <flourish:FlourishTextBox x:Name="StatusTextBox" Width="230" Text="Gallery runtime API is ready" />
            </StackPanel>
            <flourish:FlourishButton Margin="0,20,0,0" Click="UpsertStatus_Click" Content="Add / update" />
            <flourish:FlourishButton Margin="8,20,0,0" Click="ShowTimedStatus_Click" Content="Show for 4 seconds" />
            <flourish:FlourishButton Margin="8,20,0,0" Click="ToggleStatusVisible_Click" Content="Show / hide" />
            <flourish:FlourishButton Margin="8,20,0,0" Click="MoveStatus_Click" Content="Move item" />
            <flourish:FlourishButton Margin="8,20,0,0" Click="RemoveStatus_Click" Content="Remove" />
          </WrapPanel>
          <WrapPanel Margin="0,12,0,0">
            <flourish:FlourishButton Click="ToggleLan_Click" Content="Toggle LAN indicator" />
            <flourish:FlourishButton Margin="8,0,0,0" Click="TogglePower_Click" Content="Toggle power indicator" />
            <flourish:FlourishButton Margin="8,0,0,0" Click="ToggleStatusBar_Click" Content="Enable / disable bar" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="StatusStateText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Custom shell region" />
          <flourish:FlourishTextBlock Margin="0,7,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Register a WPF element in ContentHeader. The registration can be disabled, reordered, replaced or removed while the shell is visible." TextWrapping="Wrap" />
          <WrapPanel Margin="0,14,0,0">
            <flourish:FlourishButton Click="AddRegion_Click" Content="Add header content" />
            <flourish:FlourishButton Margin="8,0,0,0" Click="ToggleRegion_Click" Content="Enable / disable" />
            <flourish:FlourishButton Margin="8,0,0,0" Click="ReorderRegion_Click" Content="Change order" />
            <flourish:FlourishButton Margin="8,0,0,0" Click="RemoveRegion_Click" Content="Remove" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="RegionStateText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
