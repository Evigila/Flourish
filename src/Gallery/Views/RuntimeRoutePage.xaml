<Page
  x:Class="ArkheideSystem.Gallery.Views.RuntimeRoutePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <Grid Margin="0,32">
    <flourish:FlourishCard MaxWidth="680" Padding="28" HorizontalAlignment="Left" VerticalAlignment="Top">
      <StackPanel>
        <flourish:FlourishTextBlock Role="PageTitle" Text="A route created at runtime" />
        <flourish:FlourishTextBlock Margin="0,10,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="This page was not present in ConfigureNavigation. Its route and menu entry were registered while Gallery was already running." TextWrapping="Wrap" />
        <flourish:FlourishTextBlock Role="FieldLabel" Margin="0,22,0,0" Text="PAGE INSTANCE" />
        <flourish:FlourishTextBlock x:Name="InstanceText" FontFamily="Consolas" FontSize="16" Foreground="{DynamicResource FlourishBrandForegroundBrush}" TextWrapping="Wrap" />
        <flourish:FlourishTextBlock Role="FieldLabel" Margin="0,18,0,0" Text="NAVIGATION PARAMETER" />
        <flourish:FlourishTextBlock x:Name="ParameterText" FontFamily="Consolas" Foreground="{DynamicResource FlourishNeutralForeground1Brush}" TextWrapping="Wrap" />
      </StackPanel>
    </flourish:FlourishCard>
  </Grid>
</Page>
