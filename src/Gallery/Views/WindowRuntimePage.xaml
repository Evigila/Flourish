<Page
  x:Class="ArkheideSystem.Gallery.Views.WindowRuntimePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="0,28,0,40">
      <flourish:FlourishTextBlock Role="PageTitle" Text="Window, profile &amp; notifications" />
      <flourish:FlourishTextBlock Role="Subtitle"
        Text="Control the live shell window and tray icon, install close guards, manage the profile flyout, and publish modal or non-modal messages."
      />

      <flourish:FlourishCard Margin="0,24,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Shell window" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Resize, position, activate, and change window flags through IWindowService." TextWrapping="Wrap" />
          <WrapPanel>
            <flourish:FlourishButton Margin="0,0,8,8" Click="SetDemoSize_Click" Content="Set 1100 × 760" />
            <flourish:FlourishButton Margin="0,0,8,8" Click="CenterWindow_Click" Content="Center" />
            <flourish:FlourishButton Margin="0,0,8,8" Click="ToggleTopmost_Click" Content="Toggle topmost" />
            <flourish:FlourishButton Margin="0,0,8,8" Click="ToggleTaskbar_Click" Content="Toggle taskbar" />
            <flourish:FlourishButton Margin="0,0,8,8" Click="MinimizeWindow_Click" Content="Minimize" />
            <flourish:FlourishButton Margin="0,0,8,8" Click="MaximizeWindow_Click" Content="Maximize" />
            <flourish:FlourishButton Margin="0,0,8,8" Click="RestoreWindow_Click" Content="Restore" />
            <flourish:FlourishButton Margin="0,0,8,8" Click="HideBriefly_Click" Content="Hide for 1 second" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="WindowStatusText" Margin="0,6,0,0" Foreground="{DynamicResource FlourishBrandForegroundBrush}" TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Notification-area tray" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="The tray service can be enabled after startup and can restore a hidden shell window." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <flourish:FlourishTextBox x:Name="TrayToolTipBox" Text="Flourish Runtime Gallery" />
            <flourish:FlourishButton Grid.Column="1" Margin="10,0,0,0" Click="ApplyTrayToolTip_Click" Content="Set tray tooltip" />
          </Grid>
          <WrapPanel Margin="0,14,0,0">
            <flourish:FlourishButton x:Name="ToggleTrayButton" Margin="0,0,8,0" Click="ToggleTray_Click" />
            <flourish:FlourishButton Margin="0,0,8,0" Click="MinimizeToTray_Click" Content="Minimize to tray" />
            <flourish:FlourishButton Click="RestoreFromTray_Click" Content="Restore from tray" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="TrayStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Close behavior &amp; guards" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Choose the default close policy and install a disposable guard whose decision can change at runtime." TextWrapping="Wrap" />
          <WrapPanel>
            <flourish:FlourishComboBox x:Name="CloseBehaviorBox" Width="220" />
            <flourish:FlourishButton Margin="10,0,0,0" Click="ApplyCloseBehavior_Click" Content="Apply behavior" />
            <flourish:FlourishCheckBox x:Name="CloseGuardAllowsBox" Margin="18,0,0,0" VerticalAlignment="Center" Content="Guard allows close" IsChecked="True" />
          </WrapPanel>
          <WrapPanel Margin="0,14,0,0">
            <flourish:FlourishButton Margin="0,0,8,0" Click="RegisterCloseGuard_Click" Content="Register guard" />
            <flourish:FlourishButton Margin="0,0,8,0" Click="RemoveCloseGuard_Click" Content="Remove guard" />
            <flourish:FlourishButton Margin="0,0,8,0" Click="EvaluateClose_Click" Content="Evaluate guards" />
            <flourish:FlourishButton Click="RequestClose_Click" Content="Request app close" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="CloseStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="No close guard registered by this page." TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Profile flyout" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Enable and open the profile surface or replace its content page at runtime. Restore returns to the startup profile page type." TextWrapping="Wrap" />
          <WrapPanel>
            <flourish:FlourishButton x:Name="ToggleProfileEnabledButton" Margin="0,0,8,0" Click="ToggleProfileEnabled_Click" />
            <flourish:FlourishButton Margin="0,0,8,0" Click="ToggleProfileFlyout_Click" Content="Toggle flyout" />
            <flourish:FlourishButton Margin="0,0,8,0" Click="UseConfigurationProfilePage_Click" Content="Use configuration page" />
            <flourish:FlourishButton Click="RestoreProfilePage_Click" Content="Restore profile page" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="ProfileStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Messages &amp; notifications" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Await modal choices without blocking application logic, or publish non-modal notifications to the shell host." TextWrapping="Wrap" />
          <WrapPanel>
            <flourish:FlourishButton Margin="0,0,8,8" Click="ShowMessage_Click" Content="Show async message" />
            <flourish:FlourishButton Margin="0,0,8,8" Click="ShowCustomMessage_Click" Content="Show custom choices" />
          </WrapPanel>
          <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Notification ID" />
              <flourish:FlourishTextBox x:Name="NotificationIdBox" Text="gallery.runtime.notice" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Message" />
              <flourish:FlourishTextBox x:Name="NotificationMessageBox" Text="A runtime notification from the Gallery." />
            </StackPanel>
          </Grid>
          <WrapPanel Margin="0,14,0,0">
            <flourish:FlourishButton Margin="0,0,8,0" Click="ShowNotification_Click" Content="Show" />
            <flourish:FlourishButton Margin="0,0,8,0" Click="UpsertNotification_Click" Content="Upsert" />
            <flourish:FlourishButton Margin="0,0,8,0" Click="DismissNotification_Click" Content="Dismiss ID" />
            <flourish:FlourishButton Click="DismissAllNotifications_Click" Content="Dismiss all" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="MessageStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishBrandForegroundBrush}" TextWrapping="Wrap" />
          <flourish:FlourishTextBlock x:Name="NotificationStatusText" Margin="0,6,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
