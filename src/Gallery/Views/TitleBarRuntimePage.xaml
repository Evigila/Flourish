<Page
  x:Class="ArkheideSystem.Gallery.Views.TitleBarRuntimePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="0,28,0,40">
      <flourish:FlourishTextBlock Role="PageTitle" Text="Title bar &amp; search" />
      <flourish:FlourishTextBlock Role="Subtitle"
        Text="Update shell identity, toggle individual title-bar elements, and bind asynchronous search logic after the window has already started."
      />

      <flourish:FlourishCard Margin="0,24,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Identity" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Title and subtitle changes are reflected by the existing shell instance." />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Title" />
              <flourish:FlourishTextBox x:Name="TitleBox" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Subtitle" />
              <flourish:FlourishTextBox x:Name="SubtitleBox" />
            </StackPanel>
            <flourish:FlourishButton Grid.Column="2" Margin="8,20,0,0" Click="ApplyIdentity_Click" Content="Apply identity" />
          </Grid>
          <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Logo path (optional)" />
              <flourish:FlourishTextBox x:Name="LogoPathBox" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Logo fallback text" />
              <flourish:FlourishTextBox x:Name="LogoFallbackBox" />
            </StackPanel>
            <flourish:FlourishButton Grid.Column="2" Margin="8,20,0,0" Click="ApplyLogo_Click" Content="Apply logo" />
          </Grid>
          <flourish:FlourishTextBlock x:Name="IdentityStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishBrandForegroundBrush}" TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Element visibility" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Each title-bar element can be shown or hidden independently; breadcrumb behavior has an additional display policy." TextWrapping="Wrap" />
          <WrapPanel>
            <flourish:FlourishComboBox x:Name="TitleBarElementBox" Width="220" SelectionChanged="TitleBarElementBox_SelectionChanged" />
            <flourish:FlourishCheckBox x:Name="TitleBarElementVisibleBox" Margin="18,0,0,0" VerticalAlignment="Center" Content="Visible" />
            <flourish:FlourishButton Margin="18,0,0,0" Click="ApplyElementVisibility_Click" Content="Apply visibility" />
          </WrapPanel>
          <WrapPanel Margin="0,14,0,0">
            <flourish:FlourishComboBox x:Name="BreadcrumbModeBox" Width="220" />
            <flourish:FlourishButton Margin="18,0,0,0" Click="ApplyBreadcrumbMode_Click" Content="Apply breadcrumb mode" />
          </WrapPanel>
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Runtime search binding" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="This page owns a disposable asynchronous query subscription. Type here or in the real title-bar search box to exercise it." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <flourish:FlourishTextBox x:Name="SearchTextBox" Text="runtime API" />
            <flourish:FlourishButton Grid.Column="1" Margin="10,0,0,0" Click="SetSearchText_Click" Content="Set query" />
            <flourish:FlourishButton Grid.Column="2" Margin="8,0,0,0" Click="FocusSearch_Click" Content="Focus search" />
            <flourish:FlourishButton Grid.Column="3" Margin="8,0,0,0" Click="ClearSearch_Click" Content="Clear" />
          </Grid>
          <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <flourish:FlourishTextBox x:Name="SearchPlaceholderBox" />
            <flourish:FlourishButton Grid.Column="1" Margin="10,0,0,0" Click="ApplySearchPlaceholder_Click" Content="Set placeholder" />
            <flourish:FlourishButton x:Name="ToggleSearchVisibilityButton" Grid.Column="2" Margin="8,0,0,0" Click="ToggleSearchVisibility_Click" />
          </Grid>
          <flourish:FlourishTextBlock x:Name="SearchStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishBrandForegroundBrush}" Text="Waiting for a query." TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="High-level shell features" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Feature switches coordinate whole shell surfaces, while the controls above manage their detailed state." TextWrapping="Wrap" />
          <WrapPanel>
            <flourish:FlourishComboBox x:Name="ShellFeatureBox" Width="220" SelectionChanged="ShellFeatureBox_SelectionChanged" />
            <flourish:FlourishCheckBox x:Name="ShellFeatureEnabledBox" Margin="18,0,0,0" VerticalAlignment="Center" Content="Enabled" />
            <flourish:FlourishButton Margin="18,0,0,0" Click="ApplyShellFeature_Click" Content="Apply feature" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="ShellFeatureStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" />
        </StackPanel>
      </flourish:FlourishCard>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
