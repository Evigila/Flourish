<Page
  x:Class="ArkheideSystem.Gallery.Views.TitleBarRuntimePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        ChunkHeroDescription="Change title-bar identity, features, and search at runtime."
        ChunkHeroTitle="Title bar &amp; search"
      />

      <flourish:Chunk
        ChunkDescription="Update shell identity values."
        ChunkTitle="Identity"
      >
        <flourish:Card
          Title="Window identity"
          Text="Title, subtitle, and logo changes are reflected by the existing shell instance."
        >
          <flourish:Card.Body>
            <StackPanel>
              <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Margin="0,0,8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Title" />
                <flourish:FlourishTextBox x:Name="TitleBox" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Subtitle" />
                <flourish:FlourishTextBox x:Name="SubtitleBox" />
              </StackPanel>
              <flourish:Button Grid.Column="2" Margin="8,20,0,0" Click="ApplyIdentity_Click" Content="Apply identity" />
              </Grid>
              <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Margin="0,0,8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Logo path (optional)" />
                <flourish:FlourishTextBox x:Name="LogoPathBox" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Logo fallback text" />
                <flourish:FlourishTextBox x:Name="LogoFallbackBox" />
              </StackPanel>
              <flourish:Button Grid.Column="2" Margin="8,20,0,0" Click="ApplyLogo_Click" Content="Apply logo" />
              </Grid>
              <flourish:FlourishTextBlock x:Name="IdentityStatusText" Margin="0,12,0,0" Role="Status" />
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Toggle individual title-bar elements."
        ChunkTitle="Element visibility"
      >
        <flourish:Card
          Title="Element controls"
          Text="Each element can be shown or hidden independently, while breadcrumbs provide an additional display policy."
        >
          <flourish:Card.Body>
            <StackPanel>
              <WrapPanel>
                <flourish:FlourishComboBox x:Name="TitleBarElementBox" Width="220" SelectionChanged="TitleBarElementBox_SelectionChanged" />
                <flourish:FlourishCheckBox x:Name="TitleBarElementVisibleBox" Margin="18,0,0,0" VerticalAlignment="Center" Content="Visible" />
                <flourish:Button Margin="18,0,0,0" Click="ApplyElementVisibility_Click" Content="Apply visibility" />
              </WrapPanel>
              <WrapPanel Margin="0,14,0,0">
                <flourish:FlourishComboBox x:Name="BreadcrumbModeBox" Width="220" />
                <flourish:Button Margin="18,0,0,0" Click="ApplyBreadcrumbMode_Click" Content="Apply breadcrumb mode" />
              </WrapPanel>
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Bind and exercise asynchronous search."
        ChunkTitle="Runtime search binding"
      >
        <flourish:Card
          Title="Search subscription"
          Text="This page owns a disposable asynchronous query subscription shared with the real title-bar search box."
        >
          <flourish:Card.Body>
            <StackPanel>
              <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <flourish:FlourishTextBox x:Name="SearchTextBox" Text="runtime API" />
              <flourish:Button Grid.Column="1" Margin="10,0,0,0" Click="SetSearchText_Click" Content="Set query" />
              <flourish:Button Grid.Column="2" Margin="8,0,0,0" Click="FocusSearch_Click" Content="Focus search" />
              <flourish:Button Grid.Column="3" Margin="8,0,0,0" Click="ClearSearch_Click" Content="Clear" />
              </Grid>
              <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <flourish:FlourishTextBox x:Name="SearchPlaceholderBox" />
              <flourish:Button Grid.Column="1" Margin="10,0,0,0" Click="ApplySearchPlaceholder_Click" Content="Set placeholder" />
              <flourish:Button x:Name="ToggleSearchVisibilityButton" Grid.Column="2" Margin="8,0,0,0" Click="ToggleSearchVisibility_Click" />
              </Grid>
              <flourish:FlourishTextBlock x:Name="SearchStatusText" Margin="0,12,0,0" Role="Status" Text="Waiting for a query." />
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Toggle complete shell capabilities."
        ChunkTitle="High-level shell features"
      >
        <flourish:Card
          Title="Feature switches"
          Text="Feature switches coordinate complete shell surfaces, while the controls above manage their detailed state."
        >
          <flourish:Card.Body>
            <StackPanel>
              <WrapPanel>
                <flourish:FlourishComboBox x:Name="ShellFeatureBox" Width="220" SelectionChanged="ShellFeatureBox_SelectionChanged" />
                <flourish:FlourishCheckBox x:Name="ShellFeatureEnabledBox" Margin="18,0,0,0" VerticalAlignment="Center" Content="Enabled" />
                <flourish:Button Margin="18,0,0,0" Click="ApplyShellFeature_Click" Content="Apply feature" />
              </WrapPanel>
              <flourish:FlourishTextBlock x:Name="ShellFeatureStatusText" Margin="0,12,0,0" Role="Description" />
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
      </flourish:Chunk>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
