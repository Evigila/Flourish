<Page
  x:Class="ArkheideSystem.Gallery.Views.AppearancePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="0,28,0,40">
      <flourish:FlourishTextBlock Role="PageTitle" Text="Appearance &amp; motion" />
      <flourish:FlourishTextBlock Role="Subtitle"
        Text="Change visual resources and shell effects at runtime. Every control below calls a public service and reports the effective state returned by Flourish."
      />

      <flourish:FlourishCard Margin="0,24,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Theme" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Select a requested mode or cycle through System, Light, and Dark." />
          <WrapPanel>
            <flourish:FlourishComboBox x:Name="ThemeBox" Width="220" />
            <flourish:FlourishButton Margin="10,0,0,0" Click="ApplyTheme_Click" Content="Apply theme" />
            <flourish:FlourishButton Margin="8,0,0,0" Click="ToggleTheme_Click" Content="Cycle theme" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="ThemeStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishBrandForegroundBrush}" />
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Typography" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Update text family, base size, and icon family resources without rebuilding the visual tree." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Text font family" />
              <flourish:FlourishTextBox x:Name="FontFamilyBox" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Base size" />
              <flourish:FlourishTextBox x:Name="FontSizeBox" />
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="8,0,0,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Icon font family" />
              <flourish:FlourishTextBox x:Name="IconFontFamilyBox" />
            </StackPanel>
          </Grid>
          <flourish:FlourishButton Margin="0,14,0,0" HorizontalAlignment="Left" Click="ApplyFont_Click" Content="Apply typography" />
          <flourish:FlourishTextBlock x:Name="FontStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" TextWrapping="Wrap" />

          <Border Margin="0,18,0,0" BorderBrush="{DynamicResource FlourishCardStrokeBrush}" BorderThickness="0,1,0,0" />
          <flourish:FlourishTextBlock Role="SectionTitle" Margin="0,16,0,0" Text="This page override" />
          <flourish:FlourishTextBlock Margin="0,5,0,14" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Override only AppearancePage. Leave size empty to keep following the global base size, then clear the override to return to the global font." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="150" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Override font family" />
              <flourish:FlourishTextBox x:Name="PageOverrideFontFamilyBox" Text="Georgia" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Override size (optional)" />
              <flourish:FlourishTextBox x:Name="PageOverrideFontSizeBox" />
            </StackPanel>
            <flourish:FlourishButton Grid.Column="2" Margin="8,20,0,0" Click="ApplyPageFontOverride_Click" Content="Apply page override" />
            <flourish:FlourishButton Grid.Column="3" Margin="8,20,0,0" Click="ClearPageFontOverride_Click" Content="Clear override" />
          </Grid>
          <flourish:FlourishTextBlock x:Name="PageFontOverrideStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishBrandForegroundBrush}" TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Tooltips" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Enable or disable Flourish tooltips and change their initial delay and spawn margin." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Initial delay (ms)" />
              <flourish:FlourishTextBox x:Name="ToolTipDelayBox" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Spawn margin" />
              <flourish:FlourishTextBox x:Name="ToolTipMarginBox" />
            </StackPanel>
            <flourish:FlourishButton Grid.Column="2" Margin="8,20,0,0" Click="ConfigureToolTip_Click" Content="Apply settings" />
            <flourish:FlourishButton x:Name="ToggleToolTipButton" Grid.Column="3" Margin="8,20,0,0" Click="ToggleToolTip_Click" />
          </Grid>
          <flourish:FlourishTextBlock x:Name="ToolTipStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" />
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Motion" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Change transitions and timing, including whether system reduced-motion preferences suppress animation." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Page transition" />
              <flourish:FlourishComboBox x:Name="PageTransitionBox" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Duration (ms)" />
              <flourish:FlourishTextBox x:Name="PageDurationBox" />
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="8,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Navigation transition" />
              <flourish:FlourishComboBox x:Name="NavigationTransitionBox" />
            </StackPanel>
            <StackPanel Grid.Column="3" Margin="8,0,0,0">
              <flourish:FlourishTextBlock Role="FieldLabel" Text="Duration (ms)" />
              <flourish:FlourishTextBox x:Name="NavigationDurationBox" />
            </StackPanel>
          </Grid>
          <WrapPanel Margin="0,14,0,0">
            <flourish:FlourishCheckBox x:Name="MotionEnabledBox" Margin="0,0,22,0" VerticalAlignment="Center" Content="Motion enabled" />
            <flourish:FlourishCheckBox x:Name="HoverRevealBox" Margin="0,0,22,0" VerticalAlignment="Center" Content="Hover reveal" />
            <flourish:FlourishCheckBox x:Name="ReducedMotionBox" Margin="0,0,22,0" VerticalAlignment="Center" Content="Respect system reduced motion" />
            <flourish:FlourishButton Click="ApplyMotion_Click" Content="Apply motion" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="MotionStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>

      <flourish:FlourishCard Margin="0,16,0,0">
        <StackPanel>
          <flourish:FlourishTextBlock Role="SectionTitle" Text="Window material" />
          <flourish:FlourishTextBlock Margin="0,5,0,16" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" Text="Request the native backdrop and immersive dark mode. Flourish reports platform support and whether the effect was actually applied." TextWrapping="Wrap" />
          <WrapPanel>
            <flourish:FlourishComboBox x:Name="MaterialBox" Width="220" />
            <flourish:FlourishCheckBox x:Name="MaterialDarkModeBox" Margin="18,0,0,0" VerticalAlignment="Center" Content="Immersive dark mode" />
            <flourish:FlourishButton Margin="18,0,0,0" Click="ApplyMaterial_Click" Content="Apply material" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="MaterialStatusText" Margin="0,12,0,0" Foreground="{DynamicResource FlourishNeutralForeground2Brush}" TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
